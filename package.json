    "reactive-dom",
    "path-based",
    "zero-build"
  ],
  "author": {
    "name": "Ajdin Imsirovic",
    "url": "https://www.linkedin.com/in/ajdin-imsirovic"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ImsirovicAjdin/everystate-view"
  },
  "homepage": "https://github.com/ImsirovicAjdin/everystate-view",
  "peerDependencies": {
    "@everystate/core": ">=1.0.5"
  },
  "scripts": {
    "test": "node self-test.js",
    "self-test": "node self-test.js",
    "test:integration": "node tests/view.test.js",
    "test:i": "node tests/view.test.js"
  },
  "devDependencies": {
    "@everystate/test": "^1.0.0"
